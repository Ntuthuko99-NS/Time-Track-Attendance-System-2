import React, { useState } from "react";
import { ntuthuko } from "@/api/ntuthukoClient";
import { useQuery, useMutation, useQueryClient } from "@tanstack/react-query";

import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Tabs, TabsList, TabsTrigger } from "@/components/ui/tabs";
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";

import {
  Bell,
  Clock,
  AlertTriangle,
  UserX,
  TrendingUp,
  Check,
  X,
  Mail,
  RefreshCw,
} from "lucide-react";

import { formatDistanceToNow } from "date-fns";
import { toast } from "sonner";

import {
  checkShiftAlerts,
  sendAlertEmail,
} from "@/components/alerts/AlertService";
import WhatsAppConnect from "@/components/alerts/WhatsAppConnect";

// Alert icons
const ALERT_ICONS = {
  shift_reminder: Clock,
  late_arrival: AlertTriangle,
  missed_shift: UserX,
  overtime_warning: TrendingUp,
  forgot_clock_out: Clock,
};

// Alert colors
const ALERT_COLORS = {
  shift_reminder: "bg-blue-50 text-blue-700 border-blue-200",
  late_arrival: "bg-amber-50 text-amber-700 border-amber-200",
  missed_shift: "bg-red-50 text-red-700 border-red-200",
  overtime_warning: "bg-purple-50 text-purple-700 border-purple-200",
  forgot_clock_out: "bg-orange-50 text-orange-700 border-orange-200",
};

export default function Alerts() {
  const queryClient = useQueryClient();

  const [checking, setChecking] = useState(false);
  const [activeTab, setActiveTab] = useState("pending");

  // Fetch alerts
  const { data: alerts = [], isLoading } = useQuery({
    queryKey: ["alerts"],
    queryFn: async () => {
      const res = await ntuthuko.get("/alerts?limit=200&sort=-created_date");
      return res.data || [];
    },
  });

  // Fetch employees
  const { data: employees = [] } = useQuery({
    queryKey: ["employees"],
    queryFn: async () => {
      const res = await ntuthuko.get("/employees");
      return res.data || [];
    },
  });

  // Update alert
  const updateAlert = useMutation({
    mutationFn: async ({ id, data }) => {
      await ntuthuko.put(`/alerts/${id}`, data);
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ["alerts"] });
    },
  });

  // Generate alerts
  const handleCheckAlerts = async () => {
    setChecking(true);

    const newAlerts = await checkShiftAlerts();
    queryClient.invalidateQueries({ queryKey: ["alerts"] });

    toast.success(`${newAlerts.length} alerts generated`);
    setChecking(false);
  };

  // Actions
  const handleDismiss = (alert) => {
    updateAlert.mutate({
      id: alert.id,
      data: { status: "dismissed" },
    });
  };

  const handleMarkRead = (alert) => {
    updateAlert.mutate({
      id: alert.id,
      data: { status: "read" },
    });
  };

  const handleSendEmail = async (alert) => {
    const employee = employees.find(
      (e) => e.employee_id === alert.employee_id
    );

    if (!employee?.email) {
      toast.error("No email found");
      return;
    }

    const success = await sendAlertEmail(alert, employee.email);

    if (success) {
      toast.success("Email sent");
      queryClient.invalidateQueries({ queryKey: ["alerts"] });
    }
  };

  const handleBulkSendEmails = async () => {
    const pendingAlerts = alerts.filter(
      (a) => a.status === "pending"
    );

    let sent = 0;

    for (const alert of pendingAlerts) {
      const employee = employees.find(
        (e) => e.employee_id === alert.employee_id
      );

      if (employee?.email) {
        const success = await sendAlertEmail(
          alert,
          employee.email
        );
        if (success) sent++;
      }
    }

    toast.success(`${sent} emails sent`);
    queryClient.invalidateQueries({ queryKey: ["alerts"] });
  };

  // Filtering
  const filteredAlerts = {
    pending: alerts.filter((a) => a.status === "pending"),
    sent: alerts.filter((a) => a.status === "sent"),
    all: alerts,
  };

  // Stats
  const stats = {
    pending: filteredAlerts.pending.length,
    lateArrivals: alerts.filter(
      (a) =>
        a.type === "late_arrival" &&
        a.status !== "dismissed"
    ).length,
    missedShifts: alerts.filter(
      (a) =>
        a.type === "missed_shift" &&
        a.status !== "dismissed"
    ).length,
  };

  return (
    <div className="min-h-screen bg-slate-50 p-6">
      {/* Header */}
      <div className="flex justify-between mb-6">
        <div>
          <h1 className="text-2xl font-bold">
            Alerts & Notifications
          </h1>
          <p className="text-slate-500">
            Manage alerts and attendance issues
          </p>
        </div>

        <div className="flex gap-2">
          <Button variant="outline" onClick={handleBulkSendEmails}>
            <Mail className="w-4 h-4 mr-2" />
            Send All
          </Button>

          <Button onClick={handleCheckAlerts} disabled={checking}>
            <RefreshCw
              className={`w-4 h-4 mr-2 ${
                checking ? "animate-spin" : ""
              }`}
            />
            Check
          </Button>
        </div>
      </div>

      {/* Stats */}
      <div className="grid grid-cols-3 gap-4 mb-6">
        <Card>
          <CardContent className="p-4">
            <p className="text-xl font-bold">{stats.pending}</p>
            <p className="text-sm text-slate-500">
              Pending Alerts
            </p>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="p-4">
            <p className="text-xl font-bold">
              {stats.lateArrivals}
            </p>
            <p className="text-sm text-slate-500">
              Late Arrivals
            </p>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="p-4">
            <p className="text-xl font-bold">
              {stats.missedShifts}
            </p>
            <p className="text-sm text-slate-500">
              Missed Shifts
            </p>
          </CardContent>
        </Card>
      </div>

      <div className="grid grid-cols-3 gap-6">
        {/* Alerts Table */}
        <div className="col-span-2">
          <Card>
            <CardHeader>
              <Tabs value={activeTab} onValueChange={setActiveTab}>
                <TabsList>
                  <TabsTrigger value="pending">
                    Pending ({stats.pending})
                  </TabsTrigger>
                  <TabsTrigger value="sent">Sent</TabsTrigger>
                  <TabsTrigger value="all">All</TabsTrigger>
                </TabsList>
              </Tabs>
            </CardHeader>

            <CardContent>
              <Table>
                <TableHeader>
                  <TableRow>
                    <TableHead>Type</TableHead>
                    <TableHead>Employee</TableHead>
                    <TableHead>Message</TableHead>
                    <TableHead>Time</TableHead>
                    <TableHead>Actions</TableHead>
                  </TableRow>
                </TableHeader>

                <TableBody>
                  {filteredAlerts[activeTab].map((alert) => {
                    const Icon =
                      ALERT_ICONS[alert.type] || Bell;

                    return (
                      <TableRow key={alert.id}>
                        <TableCell>
                          <Badge
                            className={
                              ALERT_COLORS[alert.type]
                            }
                          >
                            <Icon className="w-3 h-3 mr-1" />
                            {alert.type.replace("_", " ")}
                          </Badge>
                        </TableCell>

                        <TableCell>
                          {alert.employee_name || "-"}
                        </TableCell>

                        <TableCell>
                          {alert.message}
                        </TableCell>

                        <TableCell>
                          {formatDistanceToNow(
                            new Date(alert.created_date),
                            { addSuffix: true }
                          )}
                        </TableCell>

                        <TableCell>
                          <div className="flex gap-1">
                            {alert.status === "pending" && (
                              <>
                                <Button
                                  size="sm"
                                  variant="ghost"
                                  onClick={() =>
                                    handleSendEmail(alert)
                                  }
                                >
                                  <Mail className="w-4 h-4" />
                                </Button>

                                <Button
                                  size="sm"
                                  variant="ghost"
                                  onClick={() =>
                                    handleMarkRead(alert)
                                  }
                                >
                                  <Check className="w-4 h-4" />
                                </Button>
                              </>
                            )}

                            <Button
                              size="sm"
                              variant="ghost"
                              onClick={() =>
                                handleDismiss(alert)
                              }
                            >
                              <X className="w-4 h-4" />
                            </Button>
                          </div>
                        </TableCell>
                      </TableRow>
                    );
                  })}
                </TableBody>
              </Table>
            </CardContent>
          </Card>
        </div>

        {/* WhatsApp */}
        <div>
          <WhatsAppConnect />
        </div>
      </div>
    </div>
  );
}
