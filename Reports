import React, { useState, useMemo, useEffect } from "react";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select";
import {
  Tabs,
  TabsList,
  TabsTrigger,
  TabsContent,
} from "@/components/ui/tabs";
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";
import { Badge } from "@/components/ui/badge";

import {
  Download,
  Users,
  Clock,
  TrendingUp,
  AlertTriangle,
  Calendar,
} from "lucide-react";

import {
  format,
  startOfMonth,
  endOfMonth,
  eachDayOfInterval,
  parseISO,
  isWithinInterval,
  subMonths,
} from "date-fns";

export default function Reports() {
  const [reportType, setReportType] = useState("attendance");
  const [selectedMonth, setSelectedMonth] = useState(
    format(new Date(), "yyyy-MM")
  );

  const [employees, setEmployees] = useState([]);
  const [timeEntries, setTimeEntries] = useState([]);

  // Load fake data (replace with API later)
  useEffect(() => {
    const fakeEmployees = [
      {
        employee_id: 1,
        full_name: "John Doe",
        department: "IT",
        is_active: true,
      },
    ];

    const fakeEntries = [];

    setEmployees(fakeEmployees);
    setTimeEntries(fakeEntries);
  }, []);

  // Date range
  const dateRange = useMemo(() => {
    const [year, month] = selectedMonth.split("-").map(Number);
    const date = new Date(year, month - 1, 1);

    return {
      from: startOfMonth(date),
      to: endOfMonth(date),
    };
  }, [selectedMonth]);

  // Filter entries by month
  const filteredEntries = useMemo(() => {
    return timeEntries.filter((entry) => {
      const entryDate = parseISO(entry.date);
      return isWithinInterval(entryDate, dateRange);
    });
  }, [timeEntries, dateRange]);

  // Attendance summary
  const attendanceSummary = useMemo(() => {
    const days = eachDayOfInterval(dateRange);
    const workDays = days.filter(
      (d) => d.getDay() !== 0 && d.getDay() !== 6
    ).length;

    return employees.map((emp) => {
      const empEntries = filteredEntries.filter(
        (e) => e.employee_id === emp.employee_id
      );

      const daysWorked = new Set(empEntries.map((e) => e.date)).size;

      const totalHours = empEntries.reduce(
        (sum, e) => sum + (e.total_hours || 0),
        0
      );

      const overtime = empEntries.reduce(
        (sum, e) => sum + (e.overtime_hours || 0),
        0
      );

      const attendanceRate = workDays
        ? ((daysWorked / workDays) * 100).toFixed(1)
        : 0;

      return {
        ...emp,
        daysWorked,
        totalHours,
        overtime,
        attendanceRate: Number(attendanceRate),
      };
    });
  }, [employees, filteredEntries, dateRange]);

  // Summary stats
  const totalEmployees = employees.length;

  const totalHoursWorked = attendanceSummary.reduce(
    (sum, e) => sum + e.totalHours,
    0
  );

  const totalOvertime = attendanceSummary.reduce(
    (sum, e) => sum + e.overtime,
    0
  );

  const avgAttendance =
    attendanceSummary.length > 0
      ? (
          attendanceSummary.reduce(
            (sum, e) => sum + e.attendanceRate,
            0
          ) / attendanceSummary.length
        ).toFixed(1)
      : 0;

  // Month selector
  const months = Array.from({ length: 12 }, (_, i) => {
    const date = subMonths(new Date(), i);
    return {
      value: format(date, "yyyy-MM"),
      label: format(date, "MMMM yyyy"),
    };
  });

  return (
    <div className="min-h-screen bg-slate-50 p-6">

      {/* Header */}
      <div className="flex justify-between mb-6">
        <div>
          <h1 className="text-2xl font-bold">Reports</h1>
          <p className="text-gray-500">
            Attendance and performance overview
          </p>
        </div>

        <div className="flex gap-3">
          <Select
            value={selectedMonth}
            onValueChange={setSelectedMonth}
          >
            <SelectTrigger className="w-40">
              <Calendar className="w-4 h-4 mr-2" />
              <SelectValue />
            </SelectTrigger>
            <SelectContent>
              {months.map((m) => (
                <SelectItem key={m.value} value={m.value}>
                  {m.label}
                </SelectItem>
              ))}
            </SelectContent>
          </Select>

          <Button variant="outline">
            <Download className="w-4 h-4 mr-2" />
            Export
          </Button>
        </div>
      </div>

      {/* Summary Cards */}
      <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <Card>
          <CardContent className="p-4">
            <p className="text-sm text-gray-500">Employees</p>
            <p className="text-xl font-bold">{totalEmployees}</p>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="p-4">
            <p className="text-sm text-gray-500">Total Hours</p>
            <p className="text-xl font-bold">
              {totalHoursWorked.toFixed(0)}
            </p>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="p-4">
            <p className="text-sm text-gray-500">Overtime</p>
            <p className="text-xl font-bold text-yellow-600">
              {totalOvertime.toFixed(0)}h
            </p>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="p-4">
            <p className="text-sm text-gray-500">
              Avg Attendance
            </p>
            <p className="text-xl font-bold">
              {avgAttendance}%
            </p>
          </CardContent>
        </Card>
      </div>

      {/* Tabs */}
      <Tabs value={reportType} onValueChange={setReportType}>
        <TabsList>
          <TabsTrigger value="attendance">Attendance</TabsTrigger>
          <TabsTrigger value="overtime">Overtime</TabsTrigger>
        </TabsList>

        {/* Attendance Table */}
        <TabsContent value="attendance">
          <Card>
            <CardHeader>
              <CardTitle>Attendance</CardTitle>
            </CardHeader>
            <CardContent>
              <Table>
                <TableHeader>
                  <TableRow>
                    <TableHead>Employee</TableHead>
                    <TableHead>Department</TableHead>
                    <TableHead>Days</TableHead>
                    <TableHead>Hours</TableHead>
                    <TableHead>Attendance</TableHead>
                  </TableRow>
                </TableHeader>

                <TableBody>
                  {attendanceSummary.map((emp) => (
                    <TableRow key={emp.employee_id}>
                      <TableCell>{emp.full_name}</TableCell>
                      <TableCell>{emp.department}</TableCell>
                      <TableCell>{emp.daysWorked}</TableCell>
                      <TableCell>
                        {emp.totalHours.toFixed(1)}
                      </TableCell>
                      <TableCell>
                        <Badge>
                          {emp.attendanceRate}%
                        </Badge>
                      </TableCell>
                    </TableRow>
                  ))}
                </TableBody>
              </Table>
            </CardContent>
          </Card>
        </TabsContent>

        {/* Overtime */}
        <TabsContent value="overtime">
          <Card>
            <CardHeader>
              <CardTitle>Overtime</CardTitle>
            </CardHeader>
            <CardContent>
              {attendanceSummary.length === 0 ? (
                <p className="text-gray-500">
                  No data available
                </p>
              ) : (
                <Table>
                  <TableHeader>
                    <TableRow>
                      <TableHead>Employee</TableHead>
                      <TableHead>Overtime</TableHead>
                    </TableRow>
                  </TableHeader>

                  <TableBody>
                    {attendanceSummary.map((emp) => (
                      <TableRow key={emp.employee_id}>
                        <TableCell>{emp.full_name}</TableCell>
                        <TableCell>
                          {emp.overtime.toFixed(1)}h
                        </TableCell>
                      </TableRow>
                    ))}
                  </TableBody>
                </Table>
              )}
            </CardContent>
          </Card>
        </TabsContent>
      </Tabs>
    </div>
  );
}
